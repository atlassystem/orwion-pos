# Orwion POS — ortam değişkenleri örneği
# Gerçek .env GITIGNORE'da; sırlar repoya GİRMEZ.
# İZOLASYON: yalnızca orwion_pos DB. Otelin kaptan_hotels'ine dokunma.

# MongoDB (sunucuda local, auth yok, bindIp 127.0.0.1)
MONGO_URL=mongodb://localhost:27017
DB_NAME=orwion_pos

# Çok kiracılık — tek restoran için kiracı kimliği
RESTAURANT_ID=orwion-demo

# Sedna maliyet alımı (POST /api/sedna/products) için paylaşılan API anahtarı.
# Otel ajanı (sedna_maliyet_sync.py) bu anahtarı X-API-Key başlığında gönderir.
# Gerçek anahtarı kullanıcı üretip hem POS server .env hem ajan .env'ine koyar.
# Boş/tanımsızsa alım uç noktası 503 döner. (Repoda GERÇEK anahtar OLMAZ.)
POS_SEDNA_KEY=

# Oturum imzalama anahtarı (JWT/HMAC) — gerçek auth için ZORUNLU.
# Üret: openssl rand -hex 32  → çıktıyı gerçek .env'e koy (repoya GİRMEZ).
# Boş/tanımsızsa giriş uç noktaları 503 döner.
POS_AUTH_SECRET=

# Ürün görselleri için kalıcı yükleme dizini (production'da build dışı, www-data
# yazabilir). Boşsa public/uploads kullanılır (yerel geliştirme).
# Örn (sunucu): UPLOAD_DIR=/var/www/orwion-pos/uploads
UPLOAD_DIR=
